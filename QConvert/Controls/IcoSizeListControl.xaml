<UserControl x:Class="QConvert.Controls.IcoSizeListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="5"
                Background="{StaticResource CardBrush}">
            <StackPanel x:Name="RowsHost"/>
        </Border>

        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox x:Name="SizeBox"
                     Style="{StaticResource CustomEntryBox}"
                     Width="70"
                     KeyDown="SizeBox_KeyDown"/>
            <Button Style="{StaticResource FlatButton}"
                    Content="Add"
                    Padding="10,4"
                    Margin="6,0,0,0"
                    Click="Add_Click"/>
            <TextBlock Style="{StaticResource Hint}"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"
                       Text="max 256"/>
        </StackPanel>
    </StackPanel>
</UserControl>
