<Window x:Class="QConvert.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About QConvert"
        Width="520"
        Height="520"
        ResizeMode="NoResize"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/QConvert.ico"
        Background="{StaticResource WindowBrush}">
    <Window.Resources>
        <Style x:Key="DetailLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="0,6,0,1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="DetailValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="64"
                    Height="64"
                    CornerRadius="12"
                    Background="White"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1">
                <Image Source="/Assets/QConvertLogo.png"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="Fant"/>
            </Border>

            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="QConvert"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Fast image conversion from Explorer"
                           Style="{StaticResource Hint}"
                           Margin="0,2,0,0"/>
                <TextBlock Text="Code-iX"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="About" Style="{StaticResource SectionTitle}" Margin="0,0,0,6"/>
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource Hint}"
                           Text="QConvert adds image conversion and editing actions to Windows Explorer. It converts formats, resizes, crops, compresses, removes metadata, creates favicon bundles, and opens images in the editor for previewed changes."/>

                <TextBlock Text="Included" Style="{StaticResource SectionTitle}" Margin="0,18,0,0"/>
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource Hint}"
                           Text="Explorer context menu, graphic editor, live previews, custom sizes, sepia filters, favicon export, clipboard paste, and output naming settings."/>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Version" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="VersionText" Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValue}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Author" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="AuthorText" Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValue}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Company" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="CompanyText" Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValue}"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Copyright" Style="{StaticResource DetailLabel}"/>
                    <TextBlock x:Name="CopyrightText" Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValue}"/>
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="GitHub" Style="{StaticResource DetailLabel}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValue}">
                        <Hyperlink NavigateUri="https://github.com/Matt-17/QConvert"
                                   RequestNavigate="GitHubLink_RequestNavigate"
                                   TextDecorations="None">
                            https://github.com/Matt-17/QConvert
                        </Hyperlink>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </Border>

        <Button Grid.Row="2"
                Content="Close"
                Width="90"
                IsCancel="True"
                HorizontalAlignment="Right"
                Margin="0,16,0,0"
                Style="{StaticResource PrimaryButton}"
                Click="Close_Click"/>
    </Grid>
</Window>
