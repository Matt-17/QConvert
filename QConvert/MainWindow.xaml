<Window x:Class="QConvert.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QConvert"
        Width="620" Height="700"
        MinWidth="520" MinHeight="480"
        Background="{StaticResource WindowBrush}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13">
    <DockPanel>

        <Border DockPanel.Dock="Bottom"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource FlatButton}"
                            Content="Remove context menu"
                            Click="Unregister_Click"/>
                    <Button Style="{StaticResource PrimaryButton}"
                            Content="Save &amp; update context menu"
                            Margin="8,0,0,0"
                            Click="Save_Click"/>
                </StackPanel>
                <TextBlock x:Name="StatusText"
                           Style="{StaticResource Hint}"
                           Margin="0,0,12,0"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,16,20,4">
            <StackPanel>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="JPEG quality"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Used whenever a JPG file is written."/>
                        <DockPanel Margin="0,10,0,0">
                            <TextBlock DockPanel.Dock="Right"
                                       Width="34" TextAlignment="Right" VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding ElementName=QualitySlider, Path=Value, StringFormat={}{0:0}}"/>
                            <Slider x:Name="QualitySlider"
                                    Minimum="1" Maximum="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Resize to fit"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Scales the image down (never up) so it fits inside the selected box, keeping its aspect ratio."/>
                        <WrapPanel x:Name="FitPanel" Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox x:Name="FitCustomBox" Style="{StaticResource CustomEntryBox}"
                                     KeyDown="FitCustomBox_KeyDown"/>
                            <Button Style="{StaticResource FlatButton}" Content="Add" Padding="10,4"
                                    Margin="6,0,0,0" Click="AddFitCustom_Click"/>
                            <TextBlock Style="{StaticResource Hint}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" Text="e.g. 2048x1152"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Crop to size"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Scales the image (up or down) until it covers the selected size, then crops the overlap. The result is exactly that size."/>
                        <WrapPanel x:Name="CoverPanel" Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox x:Name="CoverCustomBox" Style="{StaticResource CustomEntryBox}"
                                     KeyDown="CoverCustomBox_KeyDown"/>
                            <Button Style="{StaticResource FlatButton}" Content="Add" Padding="10,4"
                                    Margin="6,0,0,0" Click="AddCoverCustom_Click"/>
                            <TextBlock Style="{StaticResource Hint}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" Text="e.g. 1200x630"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Crop to aspect ratio"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Cuts away the left/right or top/bottom excess to reach the selected ratio. No resizing — pixels are only removed."/>
                        <WrapPanel x:Name="AspectPanel" Margin="0,12,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBox x:Name="AspectCustomBox" Style="{StaticResource CustomEntryBox}"
                                     KeyDown="AspectCustomBox_KeyDown"/>
                            <Button Style="{StaticResource FlatButton}" Content="Add" Padding="10,4"
                                    Margin="6,0,0,0" Click="AddAspectCustom_Click"/>
                            <TextBlock Style="{StaticResource Hint}" Margin="10,0,0,0"
                                       VerticalAlignment="Center" Text="e.g. 5:4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionTitle}" Text="Context menu"/>
                        <TextBlock Style="{StaticResource Hint}"
                                   Text="Right-clicking a PNG, JPG, WebP or ICO file shows a 'QConvert' submenu with the format conversions and the entries selected above. ICO output includes 16x16, 32x32, 48x48, 64x64 and 128x128 images. Saving rebuilds the menu. Converted copies keep the original name; existing names get a numeric suffix (photo.001.jpg). On Windows 11 the menu appears under 'Show more options'."/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
